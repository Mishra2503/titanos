generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Workspace {
  id        String   @id @default(uuid())
  name      String
  plan      String   @default("mvp")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users          User[]
  igAccounts     IgAccount[]
  boardColumns   BoardColumn[]
  boardCards     BoardCard[]
  mediaAssets    MediaAsset[]
  campaigns      Campaign[]
  scheduledPosts ScheduledPost[]
  competitors    Competitor[]
  snapshots      CompetitorSnapshot[]
  posts          CompetitorPost[]
  reports        CompetitorReport[]
  accessTokens   PersonalAccessToken[]
  videoAnalyses  VideoAnalysis[]
  scripts        Script[]

  @@map("workspace")
}

model User {
  id               String    @id @default(uuid())
  workspaceId      String    @map("workspace_id")
  email            String
  passwordHash     String?   @map("password_hash")
  role             String    @default("EDITOR")
  status           String    @default("ACTIVE")
  inviteTokenHash  String?   @map("invite_token_hash")
  inviteExpiresAt  DateTime? @map("invite_expires_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  accessTokens PersonalAccessToken[]

  @@unique([workspaceId, email], name: "uq_user_workspace_email")
  @@map("user")
}

// Personal Access Tokens — machine-to-machine auth for the MCP endpoint
// (LLM connectors: Claude, ChatGPT, any model). The plaintext token
// `tos_<id>_<secret>` is shown once at creation; only `token_hash`
// (sha256 of the secret) is stored. A token inherits its user's role, and
// `scopes` may narrow it further (e.g. read-only). See lib/server/pat.ts.
model PersonalAccessToken {
  id          String    @id @default(uuid())
  workspaceId String    @map("workspace_id")
  userId      String    @map("user_id")
  name        String
  tokenHash   String    @map("token_hash")
  scopes      String[]  @default([])
  lastUsedAt  DateTime? @map("last_used_at")
  expiresAt   DateTime? @map("expires_at")
  revokedAt   DateTime? @map("revoked_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([userId])
  @@map("personal_access_token")
}

// OAuth 2.1 authorization-server tables — let external LLM connectors
// (Claude Cowork, ChatGPT, Perplexity) sign in via the MCP OAuth flow instead of
// pasting a token. Access tokens are stateless JWTs (not stored here); only
// registered clients, short-lived auth codes, and refresh tokens are persisted.
// Only hashes of codes/refresh tokens are stored. See lib/server/oauth.ts.
model OAuthClient {
  id                      String   @id @default(uuid())
  clientName              String?  @map("client_name")
  redirectUris            String[] @map("redirect_uris")
  tokenEndpointAuthMethod String   @default("none") @map("token_endpoint_auth_method")
  clientSecretHash        String?  @map("client_secret_hash")
  grantTypes              String[] @default([]) @map("grant_types")
  createdAt               DateTime @default(now()) @map("created_at")

  @@map("oauth_client")
}

model OAuthAuthCode {
  id            String    @id @default(uuid())
  codeHash      String    @unique @map("code_hash")
  clientId      String    @map("client_id")
  userId        String    @map("user_id")
  workspaceId   String    @map("workspace_id")
  role          String
  redirectUri   String    @map("redirect_uri")
  codeChallenge String    @map("code_challenge")
  scope         String
  expiresAt     DateTime  @map("expires_at")
  usedAt        DateTime? @map("used_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([clientId])
  @@map("oauth_auth_code")
}

model OAuthRefreshToken {
  id          String    @id @default(uuid())
  tokenHash   String    @unique @map("token_hash")
  clientId    String    @map("client_id")
  userId      String    @map("user_id")
  workspaceId String    @map("workspace_id")
  role        String
  scope       String
  expiresAt   DateTime  @map("expires_at")
  revokedAt   DateTime? @map("revoked_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([clientId])
  @@index([userId])
  @@map("oauth_refresh_token")
}

model IgAccount {
  id              String    @id @default(uuid())
  workspaceId     String    @map("workspace_id")
  igUserId        String    @map("ig_user_id")
  username        String
  accountType     String?   @map("account_type")
  fbPageId        String?   @map("fb_page_id")
  accessTokenEnc  String    @map("access_token_enc")
  tokenExpiresAt  DateTime? @map("token_expires_at")
  status          String    @default("CONNECTED")
  followersCount  Int?      @map("followers_count")
  lastSyncedAt    DateTime? @map("last_synced_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  scheduledPosts ScheduledPost[]

  @@unique([workspaceId, igUserId], name: "uq_ig_account_workspace_iguser")
  @@map("ig_account")
}

model BoardColumn {
  id          String   @id @default(uuid())
  workspaceId String   @map("workspace_id")
  name        String
  color       String   @default("slate")
  position    Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  workspace Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  cards     BoardCard[]

  @@map("board_column")
}

model BoardCard {
  id             String   @id @default(uuid())
  workspaceId    String   @map("workspace_id")
  columnId       String   @map("column_id")
  title          String
  notes          String?
  position       Float    @default(0)
  emoji          String?
  status         String?
  platforms      Json     @default("[]")
  publishDate    String?  @map("publish_date")
  hook           String?
  visualHook     String?  @map("visual_hook")
  caption        String?
  hashtags       Json     @default("[]")
  referenceUrl   String?  @map("reference_url")
  rawFootageUrl  String?  @map("raw_footage_url")
  coverImageUrl  String?  @map("cover_image_url")
  // Set once "Script it" fills the card from a watched reel; drives the "Scripted" badge.
  scriptedAt     DateTime? @map("scripted_at")
  // Manual user tags (both the Content Board and Competitors share this concept).
  tags           Json     @default("[]")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  column        BoardColumn    @relation(fields: [columnId], references: [id], onDelete: Cascade)
  videoAnalysis VideoAnalysis? // the "watched" reference reel (source BOARD)

  @@map("board_card")
}

model MediaAsset {
  id                 String   @id @default(uuid())
  workspaceId        String   @map("workspace_id")
  filename           String
  // Object key in the S3-compatible store (R2/B2). DB column keeps its
  // historical name to avoid a rename migration; legacy rows hold Cloudinary ids.
  storageKey         String?  @map("cloudinary_public_id")
  publicUrl          String   @map("public_url")
  thumbnailUrl       String?  @map("thumbnail_url")
  width              Int?
  height             Int?
  durationS          Float?   @map("duration_s")
  format             String?
  sizeBytes          Int?     @map("size_bytes")
  uploadedBy         String?  @map("uploaded_by")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaigns Campaign[]

  @@map("media_asset")
}

model Campaign {
  id            String   @id @default(uuid())
  workspaceId   String   @map("workspace_id")
  mediaAssetId  String   @map("media_asset_id")
  title         String?
  status        String   @default("APPROVED")
  createdBy     String?  @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  mediaAsset     MediaAsset      @relation(fields: [mediaAssetId], references: [id])
  scheduledPosts ScheduledPost[]

  @@map("campaign")
}

model ScheduledPost {
  id                  String    @id @default(uuid())
  workspaceId         String    @map("workspace_id")
  campaignId          String    @map("campaign_id")
  igAccountId         String    @map("ig_account_id")
  caption             String
  hashtags            Json      @default("[]")
  scheduledAt         DateTime  @map("scheduled_at")
  status              String    @default("SCHEDULED")
  containerId         String?   @map("container_id")
  publishedMediaId    String?   @map("published_media_id")
  permalink           String?
  error               String?
  idempotencyKey      String    @unique @map("idempotency_key")
  attempts            Int       @default(0)
  processingStartedAt DateTime? @map("processing_started_at")
  publishedAt         DateTime? @map("published_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  workspace  Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaign   Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  igAccount  IgAccount  @relation(fields: [igAccountId], references: [id], onDelete: Cascade)

  @@map("scheduled_post")
}

model Competitor {
  id          String   @id @default(uuid())
  workspaceId String   @map("workspace_id")
  username    String
  displayName String?  @map("display_name")
  category    String?
  profileUrl  String?  @map("profile_url")
  avatarUrl   String?  @map("avatar_url")
  notes       String?
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  workspace Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  snapshots CompetitorSnapshot[]
  posts     CompetitorPost[]
  reports   CompetitorReport[]

  @@unique([workspaceId, username], name: "uq_competitor_workspace_username")
  @@map("competitor")
}

model CompetitorSnapshot {
  id             String   @id @default(uuid())
  workspaceId    String   @map("workspace_id")
  competitorId   String   @map("competitor_id")
  capturedOn     DateTime @map("captured_on")
  followersCount Int?     @map("followers_count")
  followingCount Int?     @map("following_count")
  postsCount     Int?     @map("posts_count")
  avgLikes       Int?     @map("avg_likes")
  avgComments    Int?     @map("avg_comments")
  engagementRate Float?   @map("engagement_rate")
  note           String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  workspace  Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  competitor Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@map("competitor_snapshot")
}

model CompetitorPost {
  id           String   @id @default(uuid())
  workspaceId  String   @map("workspace_id")
  competitorId String   @map("competitor_id")
  permalink    String?
  postType     String?  @map("post_type")
  caption      String?
  hashtags     Json     @default("[]")
  likes        Int?
  comments     Int?
  views        Int?
  postedOn     DateTime? @map("posted_on")
  thumbnailUrl String?  @map("thumbnail_url")
  videoUrl     String?  @map("video_url")
  whatWorks    String?  @map("what_works")

  // Deep on-demand research (Analyze button): hook/body/CTA + scored content ideas.
  contentAnalysis   Json?     @map("content_analysis")
  contentAnalyzedAt DateTime? @map("content_analyzed_at")

  // Manual user tags + a "used / don't reuse" marker (drives the Hide-used filter).
  tags   Json      @default("[]")
  usedAt DateTime? @map("used_at")

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  competitor    Competitor     @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  videoAnalysis VideoAnalysis?

  @@map("competitor_post")
}

// One row per "watched" video — both queue state and cached analysis result.
// COMPETITOR rows FK a CompetitorPost; OWN rows key the user's Graph media id.
// Stored videoUrl is a transient CDN link: competitor URLs refresh on re-sync,
// OWN rows re-fetch a fresh media_url from the Graph API at analysis time.
model VideoAnalysis {
  id                  String    @id @default(uuid())
  workspaceId         String    @map("workspace_id")
  source              String    // COMPETITOR | OWN | BOARD
  competitorPostId    String?   @unique @map("competitor_post_id")
  boardCardId         String?   @unique @map("board_card_id")
  igMediaId           String?   @map("ig_media_id")
  igAccountId         String?   @map("ig_account_id")
  videoUrl            String?   @map("video_url")
  status              String    @default("PENDING") // PENDING | PROCESSING | DONE | FAILED | SKIPPED
  attempts            Int       @default(0)
  processingStartedAt DateTime? @map("processing_started_at")
  error               String?
  model               String?
  durationS           Float?    @map("duration_s")
  transcript          String?
  analysis            Json?
  summary             String?
  analyzedAt          DateTime? @map("analyzed_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  competitorPost CompetitorPost? @relation(fields: [competitorPostId], references: [id], onDelete: Cascade)
  boardCard      BoardCard?      @relation(fields: [boardCardId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, igMediaId], name: "uq_video_analysis_ws_igmedia")
  @@index([status, createdAt])
  @@map("video_analysis")
}

model CompetitorReport {
  id           String   @id @default(uuid())
  workspaceId  String   @map("workspace_id")
  competitorId String?  @map("competitor_id")
  title        String
  content      String
  model        String?
  generatedAt  DateTime @map("generated_at")
  createdBy    String?  @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  workspace  Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  competitor Competitor? @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@map("competitor_report")
}

model Script {
  id               String   @id @default(uuid())
  workspaceId      String   @map("workspace_id")
  competitorId     String?  @map("competitor_id")       // plain ref (no FK) — survives competitor deletion
  competitorPostId String?  @map("competitor_post_id")
  title            String
  status           String   @default("DRAFT")           // DRAFT | APPROVED
  sourceReel       Json?    @map("source_reel")          // snapshot of the reel it came from
  research         Json?                                  // angle, trend estimate, similar creators, hook bank
  hook             String?
  body             String   @default("")                 // the full script text (editable)
  caption          String?
  hashtags         Json     @default("[]")
  model            String?
  boardCardId      String?  @map("board_card_id")        // set once pushed to the Content Board
  createdBy        String?  @map("created_by")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
  @@map("script")
}
