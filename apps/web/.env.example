# ── Database (Supabase) ────────────────────────────────────────────────────────
# Pooler URL — used at runtime for all DB queries (port 6543, pgbouncer=true)
DATABASE_URL=postgresql://postgres.YOURPROJECT:PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10

# Direct URL — used by prisma migrate deploy during build (port 5432, no pgbouncer)
DIRECT_URL=postgresql://postgres.YOURPROJECT:PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres

# ── Auth ───────────────────────────────────────────────────────────────────────
# Random 64-char hex string. Generate: openssl rand -hex 32
JWT_SECRET=

# Fernet key for encrypting Instagram tokens at rest.
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ── App URL ────────────────────────────────────────────────────────────────────
# Your public-facing URL — used for OAuth redirects and internal links.
# Local:      http://localhost:3000
# Render:     https://titan-os-web.onrender.com  (or your custom domain)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Instagram OAuth ────────────────────────────────────────────────────────────
# From Meta Developer Console → your app → Instagram settings
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# Must be registered as a Valid OAuth Redirect URI in Meta Developer Console:
# https://<your-domain>/api/connections/oauth/callback
INSTAGRAM_REDIRECT_URI=http://localhost:3000/api/connections/oauth/callback

# ── Object storage (video / image uploads — Cloudflare R2 or any S3-compatible) ─
# The browser uploads reels DIRECTLY to this store via presigned PUT URLs, so
# large files never pass through the Next server. Instagram then downloads the
# video from S3_PUBLIC_BASE_URL at publish time — the bucket must be publicly
# readable (R2: enable the r2.dev subdomain or attach a custom domain).
#
# R2 values: Cloudflare dash → R2 → your bucket / API tokens.
# Endpoint looks like: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_ENDPOINT=
# "auto" for R2 (e.g. "us-west-004" for Backblaze B2)
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
# Public base the bucket is served from, no trailing slash.
# R2: https://pub-XXXXXXXX.r2.dev  (or your custom domain, e.g. https://videos.example.com)
S3_PUBLIC_BASE_URL=

# ── Anthropic (AI scriptwriter + competitor reports + strategy) ───────────────
# Fund at console.anthropic.com. With this key set (and BEDROCK_MODEL unset),
# live web-search research turns on automatically.
ANTHROPIC_API_KEY=
# Optional — defaults to claude-sonnet-5 if not set.
# Options: claude-sonnet-5 (recommended), claude-opus-4-8 (max quality, pricier), claude-haiku-4-5 (cheapest).
# ANTHROPIC_MODEL=claude-sonnet-5

# ── AWS Bedrock (alternative Claude provider) ─────────────────────────────────
# Set BEDROCK_MODEL to route ALL Claude calls through AWS Bedrock instead of the
# Anthropic API (use when you have AWS/Bedrock credit rather than Anthropic).
# NOTE: Bedrock does NOT support Claude's hosted web_search, so live trend
# research is disabled and analysis/scripts fall back to a labelled AI estimate.
# BEDROCK_MODEL=us.anthropic.claude-sonnet-4-5-20250929-v1:0
# AWS_REGION=us-east-1
#
# Auth — pick ONE of the two options:
#   (A) EASIEST — a Bedrock API key (Bedrock console → API keys → long-term):
# AWS_BEARER_TOKEN_BEDROCK=
#   (B) Classic IAM access key + secret:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── Optional: OpenAI-compatible AI provider (local testing only) ──────────────
# Set AI_PROVIDER=openai to route ALL AI calls through an OpenAI-compatible
# endpoint (e.g. GitHub Models — free, but rate-limited and NOT for production).
# Anthropic's live web search is unavailable on this path. Leave unset for prod.
# AI_PROVIDER=openai
# OPENAI_BASE_URL=https://models.github.ai/inference
# OPENAI_MODEL=openai/gpt-5
# OPENAI_API_KEY=

# ── Video analysis ("watch the reels": frames + transcript → AI) ──────────────
# Free key from https://console.groq.com — transcribes reel audio with whisper.
# Optional: without it, videos are analyzed frames-only (no spoken-script data).
GROQ_API_KEY=
# Cheaper vision model for per-video analysis (final reports keep ANTHROPIC_MODEL)
# VIDEO_ANALYSIS_MODEL=claude-sonnet-5
# Set to "false" to disable the background video analyzer loop
# ENABLE_VIDEO_ANALYZER=true

# ── Competitor sync scraper (Apify: reel view counts + video URLs) ────────────
APIFY_TOKEN=

# ── Publisher (scheduled-post worker) ─────────────────────────────────────────
# The in-process publisher loop runs automatically every 60s. Set to "false"
# to disable (e.g. if you run an external cron against /api/schedule/tick).
# ENABLE_PUBLISHER=true

# Optional secret for triggering /api/schedule/tick from an external cron
# (send it as the x-cron-secret header).
# CRON_SECRET=

# Optional — Instagram Graph API version (defaults to v23.0)
# INSTAGRAM_GRAPH_VERSION=v23.0

# ── MCP connector (AI: Claude / ChatGPT / any LLM) ──────────────────────────────
# The app exposes an MCP endpoint at ${NEXT_PUBLIC_APP_URL}/api/mcp so LLM clients
# can drive Titan OS. It authenticates with Personal Access Tokens generated in-app
# (Settings → AI Connectors) — no extra server secret is required. NEXT_PUBLIC_APP_URL
# above is also used as the base URL for the endpoint's internal server-to-server calls.
# Optional default token lifetime in days (0 = never expires):
# PAT_DEFAULT_TTL_DAYS=0

# ── MCP OAuth sign-in (Claude Cowork / ChatGPT / Perplexity connectors) ─────────
# Titan OS is its own OAuth 2.1 authorization server for the MCP endpoint, so
# connectors can "Sign in" instead of pasting a token. It needs NO new secret —
# access tokens are JWTs signed with JWT_SECRET, and NEXT_PUBLIC_APP_URL is the
# OAuth issuer (must be the real public https URL in production). Optional TTLs:
# OAUTH_ACCESS_TTL_MIN=60
# OAUTH_REFRESH_TTL_DAYS=30
