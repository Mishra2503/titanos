# ── Database (Supabase) ────────────────────────────────────────────────────────
# Pooler URL — used at runtime for all DB queries (port 6543, pgbouncer=true)
DATABASE_URL=postgresql://postgres.YOURPROJECT:PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10

# Direct URL — used by prisma migrate deploy during build (port 5432, no pgbouncer)
DIRECT_URL=postgresql://postgres.YOURPROJECT:PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres

# ── Auth ───────────────────────────────────────────────────────────────────────
# Random 64-char hex string. Generate: openssl rand -hex 32
JWT_SECRET=

# Fernet key for encrypting Instagram tokens at rest.
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ── App URL ────────────────────────────────────────────────────────────────────
# Your public-facing URL — used for OAuth redirects and internal links.
# Local:      http://localhost:3000
# Render:     https://titan-os-web.onrender.com  (or your custom domain)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Instagram OAuth ────────────────────────────────────────────────────────────
# From Meta Developer Console → your app → Instagram settings
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# Must be registered as a Valid OAuth Redirect URI in Meta Developer Console:
# https://<your-domain>/api/connections/oauth/callback
INSTAGRAM_REDIRECT_URI=http://localhost:3000/api/connections/oauth/callback

# ── Cloudinary (video / image uploads) ────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Anthropic (AI scriptwriter + competitor reports) ──────────────────────────
ANTHROPIC_API_KEY=
# Optional — defaults to claude-opus-4-8 if not set
# ANTHROPIC_MODEL=claude-opus-4-8
