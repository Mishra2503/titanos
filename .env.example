# ============================================================================
# Titan OS — environment template. Copy to .env and fill in.
# NEVER commit a real .env. All secrets live server-side only (Rail #2).
# ============================================================================

# --- App ---
ENVIRONMENT=development                 # development | staging | production
API_BASE_URL=http://localhost:8000
WEB_BASE_URL=http://localhost:3000
# CORS: comma-separated exact origins. NEVER use "*" (Rail #2 / PRD §12).
CORS_ORIGINS=http://localhost:3000

# --- Postgres (Supabase in prod; local docker-compose for dev) ---
POSTGRES_USER=titan
POSTGRES_PASSWORD=titan_dev_password
POSTGRES_DB=titan
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Async SQLAlchemy URL. In prod use the Supabase pooled connection string.
DATABASE_URL=postgresql+asyncpg://titan:titan_dev_password@localhost:5432/titan

# --- Redis (job scheduling, rate-limit counters, insights cache) ---
REDIS_URL=redis://localhost:6379/0

# --- Auth / crypto ---
# 32-byte secret for JWT signing. Generate: openssl rand -hex 32
JWT_SECRET=change_me_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=30
# Fernet key for encrypting IG tokens at rest. Generate:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=change_me_fernet_generate_key

# --- Meta Instagram Graph API (server-side only) ---
# NOTE: the prototype's leaked secret MUST be rotated in the Meta console.
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=http://localhost:8000/api/connections/oauth/callback
INSTAGRAM_GRAPH_VERSION=v21.0

# --- Anthropic (Claude) — server-side script generation ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
# Monthly token budget guardrail (FR-SCRIPT-8)
ANTHROPIC_MONTHLY_TOKEN_BUDGET=2000000

# --- AWS Bedrock (alternative auth path to Claude) ---
# Set this INSTEAD of ANTHROPIC_API_KEY if routing AI through Bedrock.
# Long-term Bedrock API key, format: ABSK... (from AWS console -> Bedrock -> API keys)
BEDROCK_API_KEY=
BEDROCK_AWS_REGION=us-east-1
BEDROCK_MODEL=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# --- Cloudinary (master video hosting -> signed time-bound URLs) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Seconds a signed delivery URL stays valid (must outlast scheduled publish time)
CLOUDINARY_SIGNED_URL_TTL=86400

# --- GoHighLevel (lead/booking webhook in/out) ---
GHL_WEBHOOK_OUTBOUND_URL=
# Shared secret used to verify inbound GHL webhook signatures
GHL_WEBHOOK_SECRET=

# --- Observability (optional in dev) ---
SENTRY_DSN=
